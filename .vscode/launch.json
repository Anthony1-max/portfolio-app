    "version": "0.2.0",
    "configurations": [
        {
            "type": "editor-browser",
            "request": "launch",
            "name": "Launch Integrated Browser against localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
